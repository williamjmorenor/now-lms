<!doctype html>
<html lang="es">
    {% set current_theme = current_theme() %}
    <head>
        {{ current_theme.headertags() }} {{ current_theme.local_style() }}
        <title>Harvard Academic LMS - {{ site_config.nombre }}</title>
    </head>
    <body>
        {{ current_theme.navbar() }}

        <!-- Harvard Hero Section -->
        <section
            class="hero-section py-5"
            style="
                background: linear-gradient(135deg, #a41034 0%, #7a5e49 100%);
                min-height: 60vh;
                display: flex;
                align-items: center;
            "
        >
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-6 text-white">
                        <div class="hero-content">
                            <h1
                                class="display-4 fw-bold mb-4"
                                style="font-family: &quot;Merriweather&quot;, serif; text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3)"
                            >
                                Veritas et Scientia
                            </h1>
                            <p class="lead mb-4" style="font-size: 1.3rem; line-height: 1.6">
                                Bienvenido a {{ site_config.nombre }}, donde la tradición académica se encuentra con la
                                innovación educativa. Nuestra plataforma está diseñada para brindar una experiencia de
                                aprendizaje de excelencia.
                            </p>
                            <div class="d-flex gap-3 flex-wrap">
                                {% if not current_user.is_authenticated %}
                                <a href="{{ url_for('user.crear_cuenta') }}" class="btn btn-light btn-lg px-4 py-2">
                                    <strong>Comenzar Ahora</strong>
                                </a>
                                <a
                                    href="{{ url_for('course.lista_cursos', page=1) }}"
                                    class="btn btn-outline-light btn-lg px-4 py-2"
                                >
                                    Explorar Cursos
                                </a>
                                {% else %}
                                <a href="{{ url_for('home.panel') }}" class="btn btn-light btn-lg px-4 py-2">
                                    <strong>Mi Panel</strong>
                                </a>
                                <a
                                    href="{{ url_for('course.lista_cursos', page=1) }}"
                                    class="btn btn-outline-light btn-lg px-4 py-2"
                                >
                                    Ver Cursos
                                </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-6 text-center">
                        <div class="hero-visual">
                            <!-- Placeholder for Harvard-themed educational imagery -->
                            <div
                                class="academic-shield"
                                style="
                                    background: rgba(255, 255, 255, 0.1);
                                    border-radius: 50%;
                                    width: 300px;
                                    height: 300px;
                                    margin: 0 auto;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    border: 4px solid rgba(255, 255, 255, 0.3);
                                "
                            >
                                <div class="text-center text-white">
                                    <div
                                        style="
                                            font-size: 4rem;
                                            font-family: &quot;Merriweather&quot;, serif;
                                            font-weight: 700;
                                            margin-bottom: 0.5rem;
                                        "
                                    >
                                        H
                                    </div>
                                    <div style="font-size: 1.2rem; font-weight: 600">Learning Excellence</div>
                                    <div style="font-size: 0.9rem; opacity: 0.8">Since Academic Tradition</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Academic Features Section -->
        <section class="py-5" style="background: linear-gradient(135deg, #f5f3f2 0%, #e8dcc8 100%)">
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center mb-5">
                        <h2 class="display-5 fw-bold" style="color: #474340; font-family: &quot;Merriweather&quot;, serif">
                            Excelencia Académica Digital
                        </h2>
                        <p class="lead" style="color: #7a5e49; max-width: 600px; margin: 0 auto">
                            Nuestra plataforma combina los más altos estándares académicos con tecnología de vanguardia para
                            crear una experiencia educativa transformadora.
                        </p>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div
                            class="academic-feature-card h-100"
                            style="
                                background: white;
                                border-radius: 15px;
                                padding: 2rem;
                                box-shadow: 0 8px 16px rgba(164, 16, 52, 0.1);
                                border-top: 4px solid #a41034;
                            "
                        >
                            <div
                                class="feature-icon mb-3"
                                style="
                                    background: linear-gradient(45deg, #a41034, #7a5e49);
                                    width: 60px;
                                    height: 60px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                "
                            >
                                <span style="color: white; font-size: 1.5rem; font-weight: bold">📚</span>
                            </div>
                            <h4 style="color: #474340; font-family: &quot;Merriweather&quot;, serif; margin-bottom: 1rem">
                                Cursos de Élite
                            </h4>
                            <p style="color: #7a5e49; line-height: 1.6">
                                Accede a una biblioteca curada de cursos diseñados por expertos académicos, con contenido
                                riguroso y metodologías probadas.
                            </p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div
                            class="academic-feature-card h-100"
                            style="
                                background: white;
                                border-radius: 15px;
                                padding: 2rem;
                                box-shadow: 0 8px 16px rgba(164, 16, 52, 0.1);
                                border-top: 4px solid #7a5e49;
                            "
                        >
                            <div
                                class="feature-icon mb-3"
                                style="
                                    background: linear-gradient(45deg, #7a5e49, #a41034);
                                    width: 60px;
                                    height: 60px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                "
                            >
                                <span style="color: white; font-size: 1.5rem; font-weight: bold">🎓</span>
                            </div>
                            <h4 style="color: #474340; font-family: &quot;Merriweather&quot;, serif; margin-bottom: 1rem">
                                Mentores Expertos
                            </h4>
                            <p style="color: #7a5e49; line-height: 1.6">
                                Aprende de instructores distinguidos y profesionales reconocidos en sus campos, con años de
                                experiencia académica y profesional.
                            </p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div
                            class="academic-feature-card h-100"
                            style="
                                background: white;
                                border-radius: 15px;
                                padding: 2rem;
                                box-shadow: 0 8px 16px rgba(164, 16, 52, 0.1);
                                border-top: 4px solid #d8b866;
                            "
                        >
                            <div
                                class="feature-icon mb-3"
                                style="
                                    background: linear-gradient(45deg, #d8b866, #a41034);
                                    width: 60px;
                                    height: 60px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                "
                            >
                                <span style="color: white; font-size: 1.5rem; font-weight: bold">⭐</span>
                            </div>
                            <h4 style="color: #474340; font-family: &quot;Merriweather&quot;, serif; margin-bottom: 1rem">
                                Certificación Prestigiosa
                            </h4>
                            <p style="color: #7a5e49; line-height: 1.6">
                                Obtén certificaciones reconocidas que validen tu conocimiento y abran puertas en tu carrera
                                profesional y académica.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Statistics Section -->
        <section class="py-5" style="background: linear-gradient(45deg, #474340, #a41034)">
            <div class="container">
                <div class="row text-center text-white">
                    <div class="col-md-3 mb-4">
                        <div class="stat-item">
                            <h3 class="display-4 fw-bold mb-2" style="font-family: &quot;Merriweather&quot;, serif">95%</h3>
                            <p class="lead">Tasa de Finalización</p>
                        </div>
                    </div>
                    <div class="col-md-3 mb-4">
                        <div class="stat-item">
                            <h3 class="display-4 fw-bold mb-2" style="font-family: &quot;Merriweather&quot;, serif">50K+</h3>
                            <p class="lead">Estudiantes Activos</p>
                        </div>
                    </div>
                    <div class="col-md-3 mb-4">
                        <div class="stat-item">
                            <h3 class="display-4 fw-bold mb-2" style="font-family: &quot;Merriweather&quot;, serif">200+</h3>
                            <p class="lead">Cursos Disponibles</p>
                        </div>
                    </div>
                    <div class="col-md-3 mb-4">
                        <div class="stat-item">
                            <h3 class="display-4 fw-bold mb-2" style="font-family: &quot;Merriweather&quot;, serif">98%</h3>
                            <p class="lead">Satisfacción Estudiantil</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Call to Action Section -->
        <section class="py-5" style="background: linear-gradient(135deg, #e8dcc8 0%, #f5f3f2 100%)">
            <div class="container">
                <div class="row justify-content-center text-center">
                    <div class="col-lg-8">
                        <div
                            class="academic-quote"
                            style="
                                background: rgba(164, 16, 52, 0.1);
                                border-left: 4px solid #a41034;
                                padding: 2rem;
                                border-radius: 10px;
                                margin-bottom: 2rem;
                            "
                        >
                            <blockquote class="blockquote mb-0">
                                <p
                                    style="
                                        font-size: 1.25rem;
                                        font-style: italic;
                                        color: #474340;
                                        font-family: &quot;Merriweather&quot;, serif;
                                    "
                                >
                                    "La educación es el arma más poderosa que puedes usar para cambiar el mundo. En Harvard
                                    LMS, forjamos mentes brillantes para el futuro."
                                </p>
                                <footer class="blockquote-footer mt-3" style="color: #7a5e49">
                                    Filosofía Educativa <cite title="Source Title">Harvard Academic LMS</cite>
                                </footer>
                            </blockquote>
                        </div>
                        {% if not current_user.is_authenticated %}
                        <h3 class="mb-4" style="color: #474340; font-family: &quot;Merriweather&quot;, serif">
                            ¿Listo para Comenzar tu Viaje Académico?
                        </h3>
                        <p class="lead mb-4" style="color: #7a5e49">
                            Únete a nuestra comunidad de estudiantes excepcionales y descubre el poder del aprendizaje de
                            calidad.
                        </p>
                        <a
                            href="{{ url_for('user.crear_cuenta') }}"
                            class="btn btn-lg px-5 py-3"
                            style="
                                background: linear-gradient(45deg, #a41034, #7a5e49);
                                color: white;
                                border: none;
                                border-radius: 10px;
                                font-weight: 600;
                                text-decoration: none;
                            "
                        >
                            Registrarse Ahora
                        </a>
                        {% else %}
                        <h3 class="mb-4" style="color: #474340; font-family: &quot;Merriweather&quot;, serif">
                            Bienvenido de vuelta, {{ current_user.nombre }}
                        </h3>
                        <p class="lead mb-4" style="color: #7a5e49">
                            Continúa tu viaje académico y explora nuevas oportunidades de aprendizaje.
                        </p>
                        <a
                            href="{{ url_for('home.panel') }}"
                            class="btn btn-lg px-5 py-3 me-3"
                            style="
                                background: linear-gradient(45deg, #a41034, #7a5e49);
                                color: white;
                                border: none;
                                border-radius: 10px;
                                font-weight: 600;
                                text-decoration: none;
                            "
                        >
                            Ir a Mi Panel
                        </a>
                        <a
                            href="{{ url_for('course.lista_cursos', page=1) }}"
                            class="btn btn-lg btn-outline-dark px-5 py-3"
                            style="border-radius: 10px; font-weight: 600"
                        >
                            Explorar Cursos
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </section>

        <!-- Footer -->
        <footer class="footer" style="background: linear-gradient(45deg, #474340, #a41034); color: white; padding: 3rem 0">
            <div class="container">
                <div class="row">
                    <div class="col-md-6">
                        <h5 style="font-family: &quot;Merriweather&quot;, serif; margin-bottom: 1rem">Harvard Academic LMS</h5>
                        <p style="opacity: 0.9">
                            Elevando los estándares de la educación digital con la tradición y excelencia académica que nos
                            caracteriza.
                        </p>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <p style="opacity: 0.8; margin-bottom: 0">
                            <small>
                                &copy; {{ moment().year }} {{ site_config.nombre }}. Todos los derechos reservados.<br />
                                Desarrollado con dedicación académica y excelencia tecnológica.
                            </small>
                        </p>
                    </div>
                </div>
            </div>
        </footer>

        {{ current_theme.jslibs() }}
    </body>
</html>

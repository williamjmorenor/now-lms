<!doctype html>
<html lang="es">
    {% set current_theme = current_theme() %}
    <head>
        {{ current_theme.headertags() }} {{ current_theme.local_style() }}
        <title>Finance Academy - {{ site_config.nombre }}</title>
    </head>
    <body>
        {{ current_theme.navbar() }}

        <!-- Hero Section -->
        <section
            class="hero-section py-5"
            style="
                background: linear-gradient(135deg, #9bae94 0%, #365c8d 100%);
                min-height: 60vh;
                display: flex;
                align-items: center;
            "
        >
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-8 text-white">
                        <div class="hero-content">
                            <h1 class="display-4 fw-bold mb-4">Bienvenido a {{ site_config.nombre }}</h1>
                            <p class="lead mb-4" style="font-size: 1.3rem; line-height: 1.6">
                                Educación financiera de vanguardia para profesionales y empresas del sector. Nuestra plataforma
                                está diseñada para brindar una experiencia de aprendizaje excepcional.
                            </p>
                            <div class="d-flex gap-3 flex-wrap">
                                {% if not current_user.is_authenticated %}
                                <a href="{{ url_for('user.crear_cuenta') }}" class="btn btn-light btn-lg px-4 py-2">
                                    <strong>Comenzar Ahora</strong>
                                </a>
                                <a
                                    href="{{ url_for('course.lista_cursos', page=1) }}"
                                    class="btn btn-outline-light btn-lg px-4 py-2"
                                >
                                    Explorar Cursos
                                </a>
                                {% else %}
                                <a href="{{ url_for('home.panel') }}" class="btn btn-light btn-lg px-4 py-2">
                                    <strong>Mi Panel</strong>
                                </a>
                                <a
                                    href="{{ url_for('course.lista_cursos', page=1) }}"
                                    class="btn btn-outline-light btn-lg px-4 py-2"
                                >
                                    Ver Cursos
                                </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 text-center">
                        <div class="hero-visual">
                            <div
                                class="learning-icon"
                                style="
                                    background: rgba(255, 255, 255, 0.1);
                                    border-radius: 50%;
                                    width: 250px;
                                    height: 250px;
                                    margin: 0 auto;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    border: 4px solid rgba(255, 255, 255, 0.3);
                                "
                            >
                                <div class="text-center text-white">
                                    <div style="font-size: 3rem; margin-bottom: 0.5rem">📚</div>
                                    <div style="font-size: 1.2rem; font-weight: 600">Aprendizaje</div>
                                    <div style="font-size: 0.9rem; opacity: 0.8">Digital</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="py-5" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%)">
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center mb-5">
                        <h2 class="display-5 fw-bold mb-4">Aprende con Nosotros</h2>
                        <p class="lead">
                            Descubre una nueva forma de aprender con nuestra plataforma educativa moderna y eficiente.
                        </p>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div
                            class="feature-card h-100"
                            style="
                                background: white;
                                border-radius: 15px;
                                padding: 2rem;
                                box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
                                border-top: 4px solid #9bae94;
                            "
                        >
                            <div
                                class="feature-icon mb-3"
                                style="
                                    background: #9bae94;
                                    width: 60px;
                                    height: 60px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                "
                            >
                                <span style="color: white; font-size: 1.5rem">🎯</span>
                            </div>
                            <h4 class="mb-3">Cursos Especializados</h4>
                            <p style="line-height: 1.6">
                                Accede a una amplia variedad de cursos diseñados por expertos en cada área de conocimiento.
                            </p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div
                            class="feature-card h-100"
                            style="
                                background: white;
                                border-radius: 15px;
                                padding: 2rem;
                                box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
                                border-top: 4px solid #365c8d;
                            "
                        >
                            <div
                                class="feature-icon mb-3"
                                style="
                                    background: #365c8d;
                                    width: 60px;
                                    height: 60px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                "
                            >
                                <span style="color: white; font-size: 1.5rem">👥</span>
                            </div>
                            <h4 class="mb-3">Comunidad Activa</h4>
                            <p style="line-height: 1.6">
                                Únete a una comunidad de estudiantes y profesionales que comparten tus intereses y objetivos.
                            </p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div
                            class="feature-card h-100"
                            style="
                                background: white;
                                border-radius: 15px;
                                padding: 2rem;
                                box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
                                border-top: 4px solid #28a745;
                            "
                        >
                            <div
                                class="feature-icon mb-3"
                                style="
                                    background: #28a745;
                                    width: 60px;
                                    height: 60px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                "
                            >
                                <span style="color: white; font-size: 1.5rem">🏆</span>
                            </div>
                            <h4 class="mb-3">Certificaciones</h4>
                            <p style="line-height: 1.6">
                                Obtén certificaciones reconocidas que validen tu conocimiento y impulsen tu carrera
                                profesional.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Call to Action Section -->
        <section class="py-5" style="background: linear-gradient(135deg, #e9ecef 0%, #f8f9fa 100%)">
            <div class="container">
                <div class="row justify-content-center text-center">
                    <div class="col-lg-8">
                        {% if not current_user.is_authenticated %}
                        <h3 class="mb-4">¿Listo para Comenzar?</h3>
                        <p class="lead mb-4">
                            Únete a nuestra plataforma educativa y comienza tu viaje de aprendizaje hoy mismo.
                        </p>
                        <a
                            href="{{ url_for('user.crear_cuenta') }}"
                            class="btn btn-lg px-5 py-3"
                            style="
                                background: #9bae94;
                                color: white;
                                border: none;
                                border-radius: 10px;
                                font-weight: 600;
                                text-decoration: none;
                            "
                        >
                            Registrarse Gratis
                        </a>
                        {% else %}
                        <h3 class="mb-4">Bienvenido de vuelta, {{ current_user.nombre }}</h3>
                        <p class="lead mb-4">Continúa tu viaje de aprendizaje y explora nuevas oportunidades educativas.</p>
                        <a
                            href="{{ url_for('home.panel') }}"
                            class="btn btn-lg px-5 py-3 me-3"
                            style="
                                background: #9bae94;
                                color: white;
                                border: none;
                                border-radius: 10px;
                                font-weight: 600;
                                text-decoration: none;
                            "
                        >
                            Ir a Mi Panel
                        </a>
                        <a
                            href="{{ url_for('course.lista_cursos', page=1) }}"
                            class="btn btn-lg btn-outline-dark px-5 py-3"
                            style="border-radius: 10px; font-weight: 600"
                        >
                            Explorar Cursos
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </section>

        {{ current_theme.jslibs() }}
    </body>
</html>

<!doctype html>
<html lang="es">
    {% set current_theme = current_theme() %}{% set site_config = config() %}
    <head>
        {{ current_theme.headertags() }} {{ current_theme.local_style() }}
        <title>Corporate Learning - {{ site_config.nombre }}</title>
    </head>
    <body>
        {{ current_theme.navbar() }}

        <!-- Hero Section - Corporate Finance Inspired -->
        <section
            class="hero-section py-5"
            style="
                background: linear-gradient(135deg, #2c5282 0%, #1e3a8a 50%, #1e40af 100%);
                min-height: 60vh;
                display: flex;
                align-items: center;
                position: relative;
                overflow: hidden;
            "
        >
            <!-- Corporate ticker pattern overlay -->
            <div style="
                position: absolute;
                top: 15px;
                left: -100%;
                width: 200%;
                height: 25px;
                background: rgba(255, 255, 255, 0.1);
                animation: corporateTicker 25s linear infinite;
                font-family: 'Arial', sans-serif;
                font-size: 11px;
                color: rgba(255, 255, 255, 0.7);
                display: flex;
                align-items: center;
                white-space: nowrap;
                font-weight: 600;
            ">
                📊 FTSE100 +1.8% • NIKKEI +2.3% • CORPORATE TRAINING INDEX +12.5% • SKILL DEVELOPMENT FUTURES +7.9% • LEADERSHIP BONDS +5.1% • 💼
            </div>
            
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-8 text-white">
                        <div class="hero-content">
                            <h1 class="display-4 fw-bold mb-4">🏢 Excelencia Corporativa en Educación</h1>
                            <p class="lead mb-4" style="font-size: 1.3rem; line-height: 1.6">
                                📈 Soluciones de capacitación empresarial que generan valor accionario medible. 
                                Optimiza el capital humano de tu organización con metodologías de clase mundial.
                            </p>
                            <div class="d-flex gap-3 flex-wrap">
                                {% if not current_user.is_authenticated %}
                                <a href="{{ url_for('user.crear_cuenta') }}" class="btn btn-light btn-lg px-4 py-2">
                                    <strong>🚀 Iniciar Transformación</strong>
                                </a>
                                <a
                                    href="{{ url_for('course.lista_cursos', page=1) }}"
                                    class="btn btn-outline-light btn-lg px-4 py-2"
                                >
                                    📊 Explorar Soluciones
                                </a>
                                {% else %}
                                <a href="{{ url_for('home.panel') }}" class="btn btn-light btn-lg px-4 py-2">
                                    <strong>💼 Mi Dashboard</strong>
                                </a>
                                <a
                                    href="{{ url_for('course.lista_cursos', page=1) }}"
                                    class="btn btn-outline-light btn-lg px-4 py-2"
                                >
                                    📈 Ver Catálogo
                                </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 text-center">
                        <div class="hero-visual">
                            <div
                                class="learning-icon"
                                style="
                                    background: rgba(255, 255, 255, 0.1);
                                    border-radius: 50%;
                                    width: 250px;
                                    height: 250px;
                                    margin: 0 auto;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    border: 4px solid rgba(255, 255, 255, 0.3);
                                    position: relative;
                                    overflow: hidden;
                                "
                            >
                                <!-- Corporate growth chart background -->
                                <div style="
                                    position: absolute;
                                    bottom: 15px;
                                    left: 15px;
                                    right: 15px;
                                    height: 70px;
                                    opacity: 0.25;
                                ">
                                    <svg viewBox="0 0 220 70" style="width: 100%; height: 100%;">
                                        <!-- Bar chart representing growth -->
                                        <rect x="20" y="50" width="15" height="20" fill="rgba(255,255,255,0.6)"/>
                                        <rect x="40" y="45" width="15" height="25" fill="rgba(255,255,255,0.7)"/>
                                        <rect x="60" y="40" width="15" height="30" fill="rgba(255,255,255,0.8)"/>
                                        <rect x="80" y="30" width="15" height="40" fill="rgba(255,255,255,0.9)"/>
                                        <rect x="100" y="25" width="15" height="45" fill="rgba(255,255,255,1.0)"/>
                                        <!-- Trend line -->
                                        <polyline
                                            points="27,60 47,52 67,48 87,42 107,35"
                                            stroke="rgba(255,255,255,0.9)"
                                            stroke-width="2"
                                            fill="none"
                                        />
                                    </svg>
                                </div>
                                <div class="text-center text-white">
                                    <div style="font-size: 3rem; margin-bottom: 0.5rem">📊</div>
                                    <div style="font-size: 1.2rem; font-weight: 600">Capacitación</div>
                                    <div style="font-size: 0.9rem; opacity: 0.8">Corporativa</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section - Corporate Excellence -->
        <section class="py-5" style="background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%)">
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center mb-5">
                        <h2 class="display-5 fw-bold mb-4" style="color: #1e40af;">🏢 Soluciones Empresariales de Élite</h2>
                        <p class="lead" style="color: #334155;">
                            Metodologías de capacitación que transforman organizaciones y generan resultados medibles en el mercado corporativo.
                        </p>
                    </div>
                </div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div
                            class="feature-card h-100"
                            style="
                                background: white;
                                border-radius: 15px;
                                padding: 2rem;
                                box-shadow: 0 8px 16px rgba(30, 64, 175, 0.1);
                                border-top: 4px solid #1e40af;
                                border-left: 3px solid rgba(59, 130, 246, 0.3);
                            "
                        >
                            <div
                                class="feature-icon mb-3"
                                style="
                                    background: #1e40af;
                                    width: 60px;
                                    height: 60px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                "
                            >
                                <span style="color: white; font-size: 1.5rem">🎯</span>
                            </div>
                            <h4 class="mb-3" style="color: #1e40af;">Programas Ejecutivos</h4>
                            <p style="line-height: 1.6; color: #334155;">
                                Cursos de liderazgo y gestión estratégica diseñados por consultores Fortune 500 para C-Level y alta dirección.
                            </p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div
                            class="feature-card h-100"
                            style="
                                background: white;
                                border-radius: 15px;
                                padding: 2rem;
                                box-shadow: 0 8px 16px rgba(30, 64, 175, 0.1);
                                border-top: 4px solid #2563eb;
                                border-left: 3px solid rgba(59, 130, 246, 0.3);
                            "
                        >
                            <div
                                class="feature-icon mb-3"
                                style="
                                    background: #2563eb;
                                    width: 60px;
                                    height: 60px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                "
                            >
                                <span style="color: white; font-size: 1.5rem">🤝</span>
                            </div>
                            <h4 class="mb-3" style="color: #2563eb;">Network Corporativo</h4>
                            <p style="line-height: 1.6; color: #334155;">
                                Conecta con CEOs, directores y gerentes de empresas multinacionales en nuestra exclusiva red de líderes empresariales.
                            </p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div
                            class="feature-card h-100"
                            style="
                                background: white;
                                border-radius: 15px;
                                padding: 2rem;
                                box-shadow: 0 8px 16px rgba(30, 64, 175, 0.1);
                                border-top: 4px solid #3b82f6;
                                border-left: 3px solid rgba(59, 130, 246, 0.3);
                            "
                        >
                            <div
                                class="feature-icon mb-3"
                                style="
                                    background: #3b82f6;
                                    width: 60px;
                                    height: 60px;
                                    border-radius: 50%;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                "
                            >
                                <span style="color: white; font-size: 1.5rem">🏅</span>
                            </div>
                            <h4 class="mb-3" style="color: #3b82f6;">Certificaciones Elite</h4>
                            <p style="line-height: 1.6; color: #334155;">
                                Credenciales corporativas reconocidas por las principales firmas consultoras y chambers de comercio internacionales.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Featured Courses Section - Corporate Themed -->
        {% if cursos and cursos.total > 0 %}
        <section class="py-5" style="background: #ffffff">
            <div class="container">
                <div class="row">
                    <div class="col-12 text-center mb-5">
                        <h2 class="display-6 fw-bold mb-4" style="color: #7d9fb8">🏢 Desarrollo Profesional Corporativo</h2>
                        <p class="lead">Soluciones de capacitación empresarial para el crecimiento organizacional.</p>
                    </div>
                </div>
                <div class="row row-cols-1 row-cols-sm-2 g-4">
                    {% for curso in cursos.items[:4] %}
                    <div class="col">
                        <div
                            class="card h-100"
                            style="
                                border: 1px solid #a3c6e4;
                                border-radius: 8px;
                                box-shadow: 0 4px 12px rgba(163, 198, 228, 0.1);
                            "
                        >
                            {% if curso.portada and course_logo(curso.codigo) %}
                            <img
                                src="{{ url_for('static', filename='/files/public/images/' + curso.codigo + '/' + course_logo(curso.codigo)) }}"
                                alt="{{ curso.nombre }}"
                                class="card-img-top"
                                style="height: 200px; object-fit: cover; border-radius: 8px 8px 0 0"
                            />
                            {% else %}
                            <div
                                class="card-img-top d-flex align-items-center justify-content-center text-white"
                                style="
                                    height: 200px;
                                    background: linear-gradient(135deg, #a3c6e4 0%, #7d9fb8 100%);
                                    border-radius: 8px 8px 0 0;
                                "
                            >
                                <div class="text-center">
                                    <div style="font-size: 2.5rem; margin-bottom: 0.5rem">📊</div>
                                    <div style="font-size: 1rem; font-weight: 600">{{ curso.nombre }}</div>
                                </div>
                            </div>
                            {% endif %}

                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title mb-0" style="color: #7d9fb8; font-weight: 600">
                                        {{ curso.nombre }}
                                    </h5>
                                    <div class="d-flex align-items-center gap-2">
                                        {% if not curso.precio %}
                                        <span class="badge" style="background: #a3c6e4; color: white">Complimentario</span>
                                        {% endif %} {% if curso.nivel == 0 %}
                                        <span class="badge bg-light text-dark border" title="Nivel Introductorio"
                                            >Introductorio</span
                                        >
                                        {% elif curso.nivel == 1 %}
                                        <span class="badge" style="background: #a3c6e4" title="Nivel Principiante"
                                            >Principiante</span
                                        >
                                        {% elif curso.nivel == 2 %}
                                        <span class="badge" style="background: #7d9fb8" title="Nivel Intermedio"
                                            >Intermedio</span
                                        >
                                        {% elif curso.nivel == 3 %}
                                        <span class="badge bg-dark" title="Nivel Avanzado">Ejecutivo</span>
                                        {% endif %}
                                    </div>
                                </div>
                                <p class="card-text flex-grow-1" style="color: #6c757d">
                                    {{ curso.descripcion_corta | truncate(100) }}
                                </p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <a
                                        href="{{ url_for('course.curso', course_code=curso.codigo) }}"
                                        class="btn btn-sm"
                                        style="background: #7d9fb8; color: white; border: none"
                                        >📋 Acceder al Curso</a
                                    >
                                    <div class="text-end">
                                        {% if curso.duracion %}
                                        <small class="text-muted d-block">⏱️ {{ curso.duracion }} minutos</small>
                                        {% endif %} {% if curso.precio %}
                                        <small class="fw-bold" style="color: #7d9fb8"
                                            >{{ curso.precio | float }} {{ site_config.moneda }}</small
                                        >
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                <div class="text-center mt-4">
                    <a
                        href="{{ url_for('course.lista_cursos', page=1) }}"
                        class="btn btn-lg px-4 py-2"
                        style="background: #7d9fb8; color: white; border: none"
                    >
                        📚 Catálogo Completo de Capacitación
                    </a>
                </div>
            </div>
        </section>
        {% endif %}

        <!-- Call to Action Section -->
        <section class="py-5" style="background: linear-gradient(135deg, #e9ecef 0%, #f8f9fa 100%)">
            <div class="container">
                <div class="row justify-content-center text-center">
                    <div class="col-lg-8">
                        {% if not current_user.is_authenticated %}
                        <h3 class="mb-4">¿Listo para Comenzar?</h3>
                        <p class="lead mb-4">
                            Únete a nuestra plataforma educativa y comienza tu viaje de aprendizaje hoy mismo.
                        </p>
                        <a
                            href="{{ url_for('user.crear_cuenta') }}"
                            class="btn btn-lg px-5 py-3"
                            style="
                                background: #a3c6e4;
                                color: white;
                                border: none;
                                border-radius: 10px;
                                font-weight: 600;
                                text-decoration: none;
                            "
                        >
                            Registrarse Gratis
                        </a>
                        {% else %}
                        <h3 class="mb-4">Bienvenido de vuelta, {{ current_user.nombre }}</h3>
                        <p class="lead mb-4">Continúa tu viaje de aprendizaje y explora nuevas oportunidades educativas.</p>
                        <a
                            href="{{ url_for('home.panel') }}"
                            class="btn btn-lg px-5 py-3 me-3"
                            style="
                                background: #a3c6e4;
                                color: white;
                                border: none;
                                border-radius: 10px;
                                font-weight: 600;
                                text-decoration: none;
                            "
                        >
                            Ir a Mi Panel
                        </a>
                        <a
                            href="{{ url_for('course.lista_cursos', page=1) }}"
                            class="btn btn-lg btn-outline-dark px-5 py-3"
                            style="border-radius: 10px; font-weight: 600"
                        >
                            Explorar Cursos
                        </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </section>

        {{ current_theme.jslibs() }}
    </body>
</html>
